{
  "name": "memory-booth",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Memory Booth — a calm, candlelit recording booth for the celebration of Professor Tony Bailetti's life.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "wrangler dev",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "@types/node": "^22.5.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5",
    "wrangler": "^4.61.1"
  }
}
